{
  "name": "cortex",
  "displayName": "Cortex",
  "description": "A VSCode extension to quickly integrate AI into your workflow",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.76.0"
  },
  "publisher": "ChrisSahyouni",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cortex.explain",
        "title": "Explain"
      },
      {
        "command": "cortex.optimize",
        "title": "Optimize"
      },
      {
        "command": "cortex.debug",
        "title": "Debug"
      }
    ],
    "submenus": [
      {
        "id": "cortex.submenu",
        "label": "Cortex"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "cortex.submenu",
          "group": "cortex",
          "when": "editorHasSelection"
        }
      ],
      "cortex.submenu": [
        {
          "command": "cortex.debug"
        },
        {
          "command": "cortex.optimize"
        },
        {
          "command": "cortex.explain"
        }
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Chris-Sahyouni/Cortex.git"
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "node ./test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@types/vscode": "^1.76.0",
    "@vscode/test-electron": "^2.2.3",
    "esbuild": "^0.17.15",
    "eslint": "^8.34.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^4.9.5"
  },
  "dependencies": {
    "axios": "^1.3.4",
    "body-parser": "^1.20.2",
    "clipboardy": "^3.0.0",
    "express": "^4.18.2",
    "node-clipboardy": "^1.0.3",
    "openai": "^3.2.1"
  }
}
